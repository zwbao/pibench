# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Alibaba Bailian / DashScope (OpenAI-compatible endpoint) — for qwen/glm/kimi/deepseek
TONGYI_API_KEY=your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenRouter — for openai/anthropic/google models (model ids look like vendor/model)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
